# ======================================================
# 4UCS Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# ======================================================

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=4UCS Platform
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Neon:     postgresql://[user]:[password]@[host]/[db]?sslmode=require
# Local:    postgresql://postgres:password@localhost:5432/4ucs_dev
DATABASE_URL=postgresql://postgres:password@localhost:5432/4ucs_dev

# ── JWT Auth ──────────────────────────────────────────
# Must be at least 32 characters, random string
JWT_SECRET=change-this-to-a-random-32-char-secret-key

# ── NextAuth (optional - if using NextAuth alongside JWT) ─
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-another-random-secret

# ── Stripe Payments ───────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@4ucs.com
RESEND_FROM_NAME=4UCS Platform

# ── File Storage (AWS S3 or Supabase Storage) ─────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=4ucs-platform-files
# OR use Supabase storage URL
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# ── Analytics (PostHog) ───────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Feature Flags ─────────────────────────────────────
NEXT_PUBLIC_ENABLE_3D=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
